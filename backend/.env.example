# ── Node ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── MySQL (DigitalOcean Managed DB) ───────────────────────────
DB_HOST=your-db-host.db.ondigitalocean.com
DB_PORT=25060
DB_NAME=tuparley
DB_USER=tuparley_user
DB_PASSWORD=your_db_password_here
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── Redis (DigitalOcean Managed Redis) ────────────────────────
REDIS_HOST=your-redis-host.db.ondigitalocean.com
REDIS_PORT=25061
REDIS_PASSWORD=your_redis_password_here
REDIS_TLS=true

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_string_aleatorio_de_64_chars
JWT_EXPIRES_IN=14h

# ── TOTP 2FA ──────────────────────────────────────────────────
TOTP_APP_NAME=TuParley

# ── APIs Externas ─────────────────────────────────────────────
API_SPORTS_KEY=tu_api_key_de_api-sports.io
API_SPORTS_BASE_URL=https://v3.football.api-sports.io
API_BCV_URL=https://ve.dolarapi.com/v1/dolares/oficial

# ── Negocio ───────────────────────────────────────────────────
MAX_GANANCIA_USD=300
APUESTA_MINIMA_USD=1
BCV_RANGO_MINIMO=100
BCV_RANGO_MAXIMO=5000
HORAS_VENCIMIENTO_PREMIO=48
